          </div>\n        </div>\n    </nav>\n\n    <!-- About Section -->\n    <section id=\"about\" class=\"py-16 fade-in\">\n        <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n            <h2 class=\"text-3xl font-bold text-indigo-700 mb-6\">Hakkımda</h2>\n            <p class=\"text-lg leading-relaxed text-gray-600 max-w-2xl mx-auto\">\n                Merhaba, ben [İsim]. Yazarlık, şiir ve kitaplar üzerinden derinlemesine duygusal yolculuklar sunmayı seven bir yazarım. Bu sitede şiirlerim, kitaplarım ve benimle iletişime geçebileceğiniz bir form bulacaksınız.\n            </p>\n        </div>\n    </section>\n\n    <!-- Poems Section -->\n    <section id=\"poems\" class=\"py-16 bg-gray-100 fade-in\">\n        <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <h2 class=\"text-3xl font-bold text-indigo-700 mb-8 text-center\">Şiirler</h2>\n            <div class=\"space-y-6\">\n                <!-- Example Poem -->\n                <div class=\"bg-white p-6 rounded-lg shadow\">\n                    <h3 class=\"text-xl font-semibold text-indigo-600 mb-2\">Gece Yarısı</h3>\n                    <p class=\"text-gray-700 italic\">\n                        Gün ışıkları söner, gölgeler dans eder...<br>\n                        Kalbimin damakta kalan bir fısıltı gibi...\n                    </p>\n                </div>\n                <!-- Add more poems as needed -->\n            </div>\n        </div>\n    </section>\n\n    <!-- Books/Works Section -->\n    <section id=\"books\" class=\"py-16 fade-in\">\n        <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <h2 class=\"text-3xl font-bold text-indigo-700 mb-8 text-center\">Kitaplar / Eserler</h2>\n            <div class=\"grid gap-6 sm:grid-cols-2 lg:grid-cols-3\">\n                <!-- Example Book Card -->\n                <div class=\"bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition-shadow\">\n                    <div class=\"p-4\">\n                        <h3 class=\"text-lg font-medium text-indigo-600\">Karanlıkta Işık</h3>\n                        <p class=\"text-sm text-gray-500 mt-1\">Roman | 2023</p>\n                        <p class=\"text-gray-700 mt-2 line-clamp-3\">\n                            Bir kahramanın içsel strijini anlatan derin bir werk.\n                        </p>\n                    </div>\n                </div>\n                <!-- Add more book cards as needed -->\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact Section -->\n    <section id=\"contact\" class=\"py-16 bg-gray-50 fade-in\">\n        <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <h2 class=\"text-3xl font-bold text-indigo-700 mb-8 text-center\">İletişim</h2>\n            <form class=\"symmetrical-form space-y-4\" action=\"#\" method=\"POST\">\n                <div>\n                    <label for=\"name\" class=\"block text-sm font-medium text-gray-700 mb-1\">Ad Soyad</label>\n                    <input type=\"text\" id=\"name\" name=\"name\"\n                        class=\"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500\"\n                        required>\n                </div>\n                <div>\n                    <label for=\"email\" class=\"block text-sm font-medium text-gray-700 mb-1\">E-posta</label>\n                    <input type=\"email\" id=\"email\" name=\"email\"\n                        class=\"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500\"\n                        required>\n                </div>\n                <div class=\"col-span-2 sm:col-span-1\">\n                    <label for=\"subject\" class=\"block text-sm font-medium text-gray-700 mb-1\">Konu</label>\n                    <input type=\"text\" id=\"subject\" name=\"subject\"\n                        class=\"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500\"\n                        required>\n                </div>\n                <div class=\"col-span-2 sm:col-span-1\">\n                    <label for=\"message\" class=\"block text-sm font-medium text-gray-700 mb-1\">Mesaj</label>\n                    <textarea id=\"message\" name=\"message\" rows=\"5\"\n                        class=\"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500\"\n                        required></textarea>\n                </div>\n                <div class=\"col-span-2 sm:col-span-2 flex justify-end\">\n                    <button type=\"submit\"\n                        class=\"px-6 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2\">\n                        Gönder\n                    </button>\n                </div>\n            </form>\n        </div>\n    </section>\n\n    <footer class=\"bg-white py-6 text-center text-gray-500\">\n        <div class=\"max-w-7xl mx-auto px-4\">\n            &copy; <span id=\"year\"></span> Kişisel Site. Tüm hakları saklıdır.\n        </div>\n    </footer>\n\n    <script>\n        // Set current year in footer\n        document.getElementById('year').textContent = new Date().getFullYear();\n    </script>\n</body>\n</html>"},"decision":"ASK_USER"}
